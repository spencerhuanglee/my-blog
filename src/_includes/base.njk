<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }}</title>
    <style>
        * {
            box-sizing: border-box;
        }
        body {
            font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
            background-color: #ffffff;
            color: #000000;
            padding: 20px;
            max-width: 900px;
            margin: 0 auto;
            line-height: 1.65;
            font-size: 17px;
            overflow-wrap: break-word;
        }
        h1 {
            font-size: 1.5rem;
            font-weight: normal;
            margin-bottom: 20px;
        }
        .table-wrap {
            width: 100%;
            overflow-x: auto;
            -webkit-overflow-scrolling: touch;
        }
        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 10px;
        }
        th, td {
            text-align: left;
            padding: 6px 8px;
            font-size: 1rem;
            vertical-align: top;
        }
        th {
            border-bottom: 1px solid #000;
            white-space: nowrap;
        }
        td {
            border: none;
        }
        td:first-child {
            word-break: break-word;
        }
        td:nth-child(2),
        td:nth-child(3) {
            white-space: nowrap;
        }
        a {
            color: #0000EE;
            text-decoration: none;
        }
        a:hover {
            text-decoration: underline;
        }
        hr {
            border: 0;
            border-top: 1px solid #000;
            margin: 20px 0;
        }
        .footer-text {
            font-style: italic;
            color: #555;
            font-size: 0.9rem;
        }
        .post-body {
            max-width: 700px;
        }
        .post-body h1 {
            margin-bottom: 0.5em;
            font-size: 1.5rem;
        }
        .post-body h2 {
            font-size: 1.25rem;
            font-weight: normal;
            margin: 1.4em 0 0.5em;
        }
        .post-body h3 {
            font-size: 1.1rem;
            font-weight: normal;
            margin: 1.2em 0 0.4em;
        }
        .post-body p {
            margin: 0.8em 0;
        }
        .post-body img {
            max-width: 100%;
            height: auto;
        }
        .post-body pre {
            overflow-x: auto;
            -webkit-overflow-scrolling: touch;
            padding: 0.75em;
            background: #f5f5f5;
            font-size: 0.9em;
        }
        .post-body code {
            font-family: inherit;
            word-break: break-word;
        }
        .post-body pre code {
            word-break: normal;
        }
        .post-body a {
            overflow-wrap: anywhere;
        }

        @media (max-width: 640px) {
            body {
                padding: 16px;
                font-size: 18px;
            }
            h1 {
                font-size: 1.4rem;
                margin-bottom: 12px;
            }
            th, td {
                padding: 8px 4px;
            }
            /* Keep the listing to filenames on narrow screens */
            th:nth-child(2),
            th:nth-child(3),
            td:nth-child(2),
            td:nth-child(3) {
                display: none;
            }
            .post-body h1 {
                font-size: 1.45rem;
            }
            .post-body h2 {
                font-size: 1.25rem;
            }
            .post-body h3 {
                font-size: 1.1rem;
            }
        }
    </style>
</head>
<body>
{{ content | safe }}
</body>
</html>
