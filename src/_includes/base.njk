<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }}</title>
    <style>
        body {
            font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
            background-color: #ffffff;
            color: #000000;
            padding: 20px;
            max-width: 900px;
            margin: 0 auto;
            line-height: 1.6;
        }
        h1 {
            font-size: 24px;
            font-weight: normal;
            margin-bottom: 20px;
        }
        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 10px;
        }
        th, td {
            text-align: left;
            padding: 4px 8px;
            font-size: 14px;
        }
        th {
            border-bottom: 1px solid #000;
        }
        td {
            border: none;
        }
        a {
            color: #0000EE;
            text-decoration: none;
        }
        a:hover {
            text-decoration: underline;
        }
        hr {
            border: 0;
            border-top: 1px solid #000;
            margin: 20px 0;
        }
        .footer-text {
            font-style: italic;
            color: #555;
            font-size: 12px;
        }
        .post-body {
            max-width: 700px;
        }
        .post-body h1 {
            margin-bottom: 0.5em;
        }
        .post-body p {
            margin: 0.8em 0;
        }
    </style>
</head>
<body>
{{ content | safe }}
</body>
</html>
