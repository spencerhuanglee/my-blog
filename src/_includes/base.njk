<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }}</title>
    <style>
        body {
            font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
            background-color: #ffffff;
            color: #000000;
            padding: 20px;
            max-width: 900px;
            margin: 0 auto;
            line-height: 1.6;
        }
        h1 {
            font-size: 24px;
            font-weight: normal;
            margin-bottom: 20px;
        }
        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 10px;
        }
        th, td {
            text-align: left;
            padding: 4px 8px;
            font-size: 14px;
        }
        th {
            border-bottom: 1px solid #000;
        }
        td {
            border: none;
        }
        a {
            color: #0000EE;
            text-decoration: none;
        }
        a:hover {
            text-decoration: underline;
        }
        hr {
            border: 0;
            border-top: 1px solid #000;
            margin: 20px 0;
        }
        .footer-text {
            font-style: italic;
            color: #555;
            font-size: 12px;
        }
        .post-body {
            max-width: 700px;
            font-family: Georgia, "Times New Roman", Times, serif;
            font-size: 1.125rem;
            line-height: 1.7;
            overflow-wrap: break-word;
        }
        .post-body h1 {
            margin-bottom: 0.5em;
            font-size: 1.75rem;
            font-weight: normal;
            font-family: Georgia, "Times New Roman", Times, serif;
        }
        .post-body h2 {
            font-size: 1.35rem;
            font-weight: normal;
            margin: 1.4em 0 0.5em;
        }
        .post-body h3 {
            font-size: 1.15rem;
            font-weight: normal;
            margin: 1.2em 0 0.4em;
        }
        .post-body p {
            margin: 0.8em 0;
        }
        .post-body img {
            max-width: 100%;
            height: auto;
        }
        .post-body pre,
        .post-body code {
            font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
        }
        .post-body pre {
            overflow-x: auto;
            -webkit-overflow-scrolling: touch;
            padding: 0.75em;
            background: #f5f5f5;
            font-size: 0.9em;
        }
        .post-body a {
            overflow-wrap: anywhere;
        }

        @media (max-width: 640px) {
            .post-body {
                font-size: 1.2rem;
            }
            .post-body h1 {
                font-size: 1.6rem;
            }
        }
    </style>
</head>
<body>
{{ content | safe }}
</body>
</html>
