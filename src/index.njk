---
layout: base.njk
title: Index of /blog
permalink: /
---
<h1>Index of /blog</h1>
<hr>

<table>
    <thead>
        <tr>
            <th>Filename</th>
            <th>Size</th>
            <th>Last Modified</th>
        </tr>
    </thead>
    <tbody>
        <tr>
            <td><a href="../"><span>📁</span> ..</a></td>
            <td>-</td>
            <td>-</td>
        </tr>
        {%- for post in collections.posts | reverse %}
        <tr>
            <td><a href="{{ post.url }}"><span>📄</span> {{ post.fileSlug }}.html</a></td>
            <td>{{ post.templateContent | filesize }}</td>
            <td>{{ (post.date or post.data.date) | apacheDate }}</td>
        </tr>
        {%- endfor %}
    </tbody>
</table>

